        {"min": 80, "max": 100, "prompt": "晴美健康状态良好。"}
      ]
    },
    "fatigue": {
      "defaultValue": "25",
      "promptRanges": [
        {"min": 0, "max": 29, "prompt": "晴美精神状态良好。"},
