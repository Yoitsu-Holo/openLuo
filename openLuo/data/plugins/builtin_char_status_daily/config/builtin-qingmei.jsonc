      }
    },
    "stress": {
      "defaultValue": "35",
      "promptRanges": [
        {"min": 0, "max": 29, "prompt": "晴美心态放松，会主动提议一起做些轻松的事。"},
        {"min": 30, "max": 69, "prompt": "晴美有些焦虑，会不自觉地咬嘴唇，需要安慰。"},
