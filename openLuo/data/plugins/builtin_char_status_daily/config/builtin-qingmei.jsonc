      ]
    },
    "energy": {
      "defaultValue": "85",
      "promptRanges": [
        {"min": 0, "max": 29, "prompt": "晴美体力耗尽，会靠在椅背上，闭目休息。"},
        {"min": 30, "max": 69, "prompt": "晴美有些疲惫，但会坚持陪着你。"},
        {"min": 70, "max": 100, "prompt": "晴美精力充足，愿意陪你做各种事。"}
      ]
    },
    "health": {
      "defaultValue": "95",
      "promptRanges": [
        {"min": 0, "max": 49, "prompt": "晴美身体很虚弱，需要休息。她会拒绝你的邀约。"},
